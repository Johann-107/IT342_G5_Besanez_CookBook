<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.IT342_G5_BESANEZ_LAB1_MOBILE" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/terracotta</item>
        <item name="colorPrimaryDark">@color/terracotta_dark</item>
        <item name="colorAccent">@color/peach</item>
        <item name="android:windowBackground">@color/cream</item>
        <item name="android:colorBackground">@color/cream</item>
    </style>

    <style name="Theme.IT342_G5_BESANEZ_LAB1_MOBILE" parent="Base.Theme.IT342_G5_BESANEZ_LAB1_MOBILE" />

    <!-- Outlined input fields using terracotta accent -->
    <style name="CookBook.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/terracotta</item>
        <item name="hintTextColor">@color/text_mid</item>
        <item name="boxBackgroundColor">@color/warm_white</item>
    </style>

    <!-- Primary button -->
    <style name="CookBook.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/terracotta</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <!-- Ghost/outline button -->
    <style name="CookBook.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/terracotta</item>
        <item name="android:textColor">@color/terracotta</item>
        <item name="cornerRadius">10dp</item>
    </style>
</resources>