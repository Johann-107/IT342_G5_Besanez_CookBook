<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/warm_white"
        android:elevation="4dp"
        app:titleTextColor="@color/text_dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/text_mid"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Edit"
                android:layout_marginEnd="4dp" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/error"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete"
                android:layout_marginEnd="8dp" />
        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <!-- Collection header card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/warm_white"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_mid"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/terracotta"
            android:background="@color/peach_light"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@color/cream" />

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recipes"
        android:textSize="15sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textColor="@color/text_dark"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@color/warm_white" />

    <!-- States -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/terracotta"
        android:visibility="gone"
        android:layout_margin="24dp" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No recipes in this collection yet."
        android:textSize="13sp"
        android:textColor="@color/text_light"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/error"
        android:textSize="13sp"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- Recipe list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRecipes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="16dp" />

</LinearLayout>