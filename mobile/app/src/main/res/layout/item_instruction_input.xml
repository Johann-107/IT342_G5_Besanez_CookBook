<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvStepNum"
        android:layout_width="28dp" android:layout_height="28dp"
        android:gravity="center"
        android:textSize="12sp" android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/step_circle"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/etStepDesc"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:hint="Describe this step…"
        android:textSize="14sp" android:textColor="@color/text_dark"
        android:inputType="textMultiLine" android:minLines="2"
        android:background="@drawable/input_bg"
        android:padding="10dp" android:layout_marginEnd="4dp" />

    <ImageButton
        android:id="@+id/btnRemoveStep"
        android:layout_width="32dp" android:layout_height="32dp"
        android:src="@android:drawable/ic_delete"
        android:tint="@color/error"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove"
        android:layout_marginTop="8dp" />
</LinearLayout>